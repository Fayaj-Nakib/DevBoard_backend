APP_NAME=DevBoard
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=devboard
DB_USERNAME=postgres
DB_PASSWORD=
# Set to "require" for Neon or any managed PostgreSQL that enforces SSL
DB_SSLMODE=prefer

# ── Queue (use "sync" on free-tier hosting so no worker process is needed) ────
QUEUE_CONNECTION=database

# ── Cache / Session ───────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Mail ──────────────────────────────────────────────────────────────────────
# Development: MAIL_MAILER=log  (prints to laravel.log, no real email sent)
# Production:  MAIL_MAILER=smtp with Gmail App Password
#   How to get a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create a new App Password → use it as MAIL_PASSWORD below
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the deployed frontend URL (e.g. https://devboard.vercel.app)
# Comma-separate multiple origins if needed.
FRONTEND_URL=http://localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
